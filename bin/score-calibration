#!/usr/bin/env python3
"""score-calibration — SQLite version (replaces the Postgres asyncpg script).

Reads gate_events from data/calibration.sqlite, computes brier_score +
log_score + peer_score for any unscored rows, writes back. Idempotent —
re-running on already-scored rows is a no-op.

Schema: data/calibration-schema.sql.

Usage:
  bin/score-calibration                # score everything new
  bin/score-calibration --dry-run      # show what would be scored
  bin/score-calibration --since 2026-04-01  # only rows resolved on/after a date

Run after bin/init-calibration-db has set up the DB.
"""
from __future__ import annotations

import argparse
import math
import os
import sqlite3
import sys
from collections import defaultdict
from datetime import date

EPSILON = 1e-6


def _db_path() -> str:
    root = os.environ.get("SUBSTRATE_ROOT") or os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    return os.path.join(root, "data", "calibration.sqlite")


def brier(p: float, a: float) -> float:
    return (p - a) ** 2


def log_score(p: float, a: float) -> float:
    p_c = max(EPSILON, min(1.0 - EPSILON, p))
    return -math.log(p_c) if a >= 0.5 else -math.log(1.0 - p_c)


def baseline_brier_per_asset(conn: sqlite3.Connection) -> dict:
    """{asset_type: mean_brier} over rows resolved in the last 6 months with N>=10."""
    cur = conn.execute(
        """
        SELECT asset_type, AVG(brier_score) AS mean_brier, COUNT(*) AS n
          FROM gate_events
         WHERE brier_score IS NOT NULL
           AND resolved_at >= datetime('now', '-6 months')
         GROUP BY asset_type
        """
    )
    per_asset = {row[0]: float(row[1]) for row in cur if row[2] >= 10 and row[1] is not None}
    cur = conn.execute(
        """
        SELECT AVG(brier_score) FROM gate_events
         WHERE brier_score IS NOT NULL
           AND resolved_at >= datetime('now', '-6 months')
        """
    )
    global_mean = cur.fetchone()[0]
    per_asset[None] = float(global_mean) if global_mean is not None else 0.25
    return per_asset


def score(args):
    db = _db_path()
    if not os.path.exists(db):
        print(f"[score-calibration] DB not initialised: {db}", file=sys.stderr)
        print(f"[score-calibration] run: bin/init-calibration-db", file=sys.stderr)
        sys.exit(2)

    conn = sqlite3.connect(db)
    try:
        # Pull unscored rows (have predicted + actual, missing brier).
        where_since = ""
        params = []
        if args.since:
            where_since = "AND resolved_at >= ?"
            params.append(args.since.isoformat())
        sql = f"""
            SELECT event_id, asset_type, taste_owner, predicted_p_threshold_met, actual_outcome
              FROM gate_events
             WHERE predicted_p_threshold_met IS NOT NULL
               AND actual_outcome IS NOT NULL
               AND brier_score IS NULL
               {where_since}
             ORDER BY resolved_at ASC
        """
        rows = list(conn.execute(sql, params))
        if not rows:
            print("[score-calibration] no unscored rows. nothing to do.")
            return

        baseline = baseline_brier_per_asset(conn)
        updates = []
        per_owner = defaultdict(list)

        for event_id, asset_type, taste_owner, p, a in rows:
            p, a = float(p), float(a)
            b = brier(p, a)
            ls = log_score(p, a)
            base = baseline.get(asset_type, baseline.get(None, 0.25))
            peer = b - base
            updates.append((b, ls, peer, event_id))
            per_owner[taste_owner].append(b)

        if args.dry_run:
            print(f"[score-calibration] would score {len(updates)} rows")
            for b, ls, peer, eid in updates[:10]:
                print(f"  · {eid}  brier={b:.4f}  log={ls:.4f}  peer={peer:+.4f}")
            return

        with conn:
            conn.executemany(
                """
                UPDATE gate_events
                   SET brier_score = ?, log_score = ?, peer_score = ?
                 WHERE event_id = ?
                """,
                updates,
            )

        print(f"[score-calibration] scored {len(updates)} rows")
        for owner, briers in sorted(per_owner.items()):
            mean = sum(briers) / len(briers)
            print(f"  · {owner or '(no owner)':<24}  N={len(briers):3d}  mean_brier={mean:.4f}")
    finally:
        conn.close()


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--since", type=lambda s: date.fromisoformat(s), help="YYYY-MM-DD")
    args = p.parse_args()
    score(args)


if __name__ == "__main__":
    main()
