# --- minimal yaml parser (zero-dep) -----------------------------------------

def load_yaml(path: Path) -> dict | None:
    try:
        import yaml  # type: ignore[import-not-found]
        return yaml.safe_load(path.read_text())
    except ImportError:
        pass
    text = path.read_text()
    return _parse_minimal_yaml(text)


def _parse_minimal_yaml(text: str) -> dict:
    root: dict = {}
    stack: list[tuple[int, dict | list]] = [(-1, root)]
    lines = text.splitlines()
    i = 0
    while i < len(lines):
        raw = lines[i]
        line = re.sub(r"(\s)#.*$", r"\1", raw).rstrip()
        if not line.strip() or line.lstrip().startswith("#"):
            i += 1
            continue
        indent = len(line) - len(line.lstrip())
        while stack and stack[-1][0] >= indent:
            stack.pop()
        parent = stack[-1][1] if stack else root
        stripped = line.strip()
        if stripped.startswith("- "):
            value_part = stripped[2:].strip()
            if isinstance(parent, list):
                if ":" in value_part and not value_part.endswith(":"):
                    k, _, v = value_part.partition(":")
                    new_map = {k.strip(): _scalar(v.strip())}
                    parent.append(new_map)
                    stack.append((indent, new_map))
                elif value_part:
                    parent.append(_scalar(value_part))
                else:
                    new_map = {}
                    parent.append(new_map)
                    stack.append((indent, new_map))
            i += 1
            continue
        if ":" in stripped:
            key, _, val = stripped.partition(":")
            key = key.strip()
            val = val.strip()
            if not val:
                j = i + 1
                while j < len(lines) and not lines[j].strip():
                    j += 1
                if j < len(lines):
                    next_line = lines[j]
                    next_indent = len(next_line) - len(next_line.lstrip())
                    if next_indent > indent and next_line.strip().startswith("- "):
                        new_list: list = []
                        if isinstance(parent, dict):
                            parent[key] = new_list
                        stack.append((indent, new_list))
                    else:
                        new_map = {}
                        if isinstance(parent, dict):
                            parent[key] = new_map
                        stack.append((indent, new_map))
            else:
                if isinstance(parent, dict):
                    parent[key] = _scalar_or_inline(val)
        i += 1
    return root


def _scalar(v: str):
    if v.startswith('"') and v.endswith('"'):
        return v[1:-1]
    if v.startswith("'") and v.endswith("'"):
        return v[1:-1]
    if v.lower() in ("true", "false"):
        return v.lower() == "true"
    if v.lower() in ("null", "~"):
        return None
    if re.fullmatch(r"-?\d+", v):
        return int(v)
    if re.fullmatch(r"-?\d+\.\d+", v):
        return float(v)
    return v


def _scalar_or_inline(v: str):
    if v.startswith("[") and v.endswith("]"):
        inner = v[1:-1].strip()
        if not inner:
            return []
        return [_scalar(p.strip()) for p in inner.split(",")]
    if v.startswith("{") and v.endswith("}"):
        inner = v[1:-1].strip()
        out: dict = {}
        if not inner:
            return out
        for pair in inner.split(","):
            if ":" in pair:
                k, _, vv = pair.partition(":")
                out[k.strip()] = _scalar(vv.strip())
        return out
    return _scalar(v)


# --- core operations --------------------------------------------------------

def refuse(reason: str, detail: str = "") -> int:
    print(f"REFUSED: {reason}", file=sys.stderr)
    if detail:
        print(f"  {detail}", file=sys.stderr)
    return 3


def previous_month_label(today: datetime | None = None) -> str:
    today = today or datetime.now(timezone.utc)
    first_of_month = today.replace(day=1)
    last_of_prev = first_of_month - timedelta(days=1)
    return last_of_prev.strftime("%Y-%m")


def month_window(month_label: str) -> tuple[datetime, datetime]:
    """Return [start, end_exclusive] for a YYYY-MM month label."""
    m = re.fullmatch(r"(\d{4})-(\d{2})", month_label)
    if not m:
        raise ValueError(f"month must be YYYY-MM, got {month_label!r}")
    y, mo = int(m.group(1)), int(m.group(2))
    start = datetime(y, mo, 1, tzinfo=timezone.utc)
    if mo == 12:
        end = datetime(y + 1, 1, 1, tzinfo=timezone.utc)
    else:
        end = datetime(y, mo + 1, 1, tzinfo=timezone.utc)
    return start, end


def stable_seed(client: str, source: str, month: str) -> int:
    h = hashlib.sha256(f"{client}|{source}|{month}".encode()).hexdigest()
    return int(h[:8], 16)


def weighted_pick(rng: random.Random, vocab: list[tuple[str, float]]) -> str:
    r = rng.random()
    acc = 0.0
    for name, weight in vocab:
        acc += weight
        if r <= acc:
            return name
    return vocab[-1][0]


def gen_mock_amplitude(client: str, source: str, month: str, n_users: int, events_per_user: tuple[int, int]) -> list[dict]:
    rng = random.Random(stable_seed(client, source, month))
    start, end = month_window(month)
    span_seconds = int((end - start).total_seconds())
    countries = ["US", "GB", "IN", "DE", "FR", "AU", "BR", "CA", "JP"]
    devices = ["desktop", "mobile", "tablet"]
    plans = ["trial", "starter", "growth", "scale", "enterprise"]
    sources_list = ["organic", "paid-search", "referral", "direct", "social", "email"]
    personas = ["sdr-lead", "ops-lead", "founder-led", "rev-ops-pro", "csm-lead"]
    vocab = MOCK_EVENT_VOCAB[source]
    rows: list[dict] = []
    for u in range(n_users):
        user_id = f"u_{u:05d}"
        country = rng.choice(countries)
        device = rng.choice(devices)
        n_events = rng.randint(*events_per_user)
        plan = rng.choice(plans)
        team_size = rng.choice([1, 2, 3, 5, 8, 13, 25, 50])
        signup_source = rng.choice(sources_list)
        persona = rng.choice(personas)
        for e in range(n_events):
            event_name = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span_seconds))
            session_id = f"s_{u:05d}_{e // 5:03d}"
            event_id = f"ev_{u:05d}_{e:04d}"
            row = {
                "event_id": event_id,
                "user_id": user_id,
                "event_name": event_name,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "session_id": session_id,
                "country": country,
                "device_type": device,
                "property_plan": plan,
                "property_team_size": str(team_size),
                "property_signup_source": signup_source,
                "property_persona": persona,
            }
            rows.append(row)
    rows.sort(key=lambda r: r["ts"])
    return rows


def gen_mock_posthog(client: str, source: str, month: str, n_users: int, events_per_user: tuple[int, int]) -> list[dict]:
    rng = random.Random(stable_seed(client, source, month))
    start, end = month_window(month)
    span = int((end - start).total_seconds())
    plans = ["trial", "starter", "growth", "scale"]
    sources_list = ["organic", "paid-search", "referral", "direct", "social"]
    personas = ["sdr-lead", "ops-lead", "founder-led", "rev-ops-pro"]
    vocab = MOCK_EVENT_VOCAB[source]
    rows: list[dict] = []
    for u in range(n_users):
        distinct_id = f"d_{u:05d}"
        person_id = f"p_{u:05d}"
        plan = rng.choice(plans)
        signup_source = rng.choice(sources_list)
        persona = rng.choice(personas)
        team_size = rng.choice([1, 2, 5, 10, 25])
        n_events = rng.randint(*events_per_user)
        for e in range(n_events):
            event_name = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span))
            rows.append({
                "event_id": f"ph_{u:05d}_{e:04d}",
                "distinct_id": distinct_id,
                "event_name": event_name,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "session_id": f"phs_{u:05d}_{e // 5}",
                "person_id": person_id,
                "property_plan": plan,
                "property_team_size": str(team_size),
                "property_signup_source": signup_source,
                "property_persona": persona,
            })
    rows.sort(key=lambda r: r["ts"])
    return rows


