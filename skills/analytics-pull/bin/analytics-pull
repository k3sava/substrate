#!/usr/bin/env python3
"""analytics-pull, pull data from named source systems into per-client substrate.

Reads clients/<client>/analytics/sources.yaml (refuses without it). Per declared
source, fetches the previous calendar month's data and lands a schema-mapped CSV
plus manifest under clients/<client>/analytics/<source>/<YYYY-MM>.csv.

When API keys are present (env-var-named per source), the skill calls the live
API; when absent, it falls back to mock-mode and emits realistic seed data so
downstream skills can be smoke-tested before live credentials land. Mock-mode is
also forced by --mock.

Source CSV schemas (all sources lower-snake_case columns):

  amplitude: event_id, user_id, event_name, ts, session_id, country, device_type, property_*
  posthog:   event_id, distinct_id, event_name, ts, session_id, person_id, property_*
  mixpanel:  event_id, distinct_id, event_name, ts, session_id, property_*
  hubspot:   object_id, object_type, event_type, ts, owner_id, property_*
  stripe:    event_id, customer_id, event_type, ts, currency, amount_cents, plan_id, status
  segment:   event_id, user_id, anonymous_id, event_name, ts, source, property_*
  ga4:       event_id, client_id, event_name, ts, session_id, property_*

Usage:
    analytics-pull --client <client>                 # pull all sources, prev month
    analytics-pull --client <client> --source amplitude
    analytics-pull --client <client> --source amplitude --month 2026-04
    analytics-pull --client <client> --mock          # force mock-mode
    analytics-pull --client <client> --dry-run       # print intent only

Exit codes:
    0, all declared sources pulled or skipped with documented fallback
    1, partial pull (some sources failed; manifest captures which)
    3, refused (substrate gap, missing sources.yaml)
    4, invalid args
"""

from __future__ import annotations

import argparse
import csv
import hashlib
import json
import os
import random
import re
import sys
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path

SUBSTRATE_ROOT = Path(
    os.environ.get("SUBSTRATE_ROOT")
    or os.environ.get("FLYWHEEL_ROOT")
    or Path(__file__).resolve().parents[3]
)

