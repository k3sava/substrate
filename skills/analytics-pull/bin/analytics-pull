def gen_mock_hubspot(client: str, source: str, month: str, n_objects: int, events_per_object: tuple[int, int]) -> list[dict]:
    rng = random.Random(stable_seed(client, source, month))
    start, end = month_window(month)
    span = int((end - start).total_seconds())
    object_types = ["contact", "deal", "company", "ticket"]
    lifecycle_stages = ["subscriber", "lead", "marketing-qualified-lead", "sales-qualified-lead", "opportunity", "customer"]
    sources_list = ["organic-search", "paid-search", "referral", "social", "direct", "email-marketing"]
    industries = ["SaaS", "FinTech", "Healthcare", "Retail", "Manufacturing", "Media"]
    company_sizes = ["1-10", "11-50", "51-200", "201-500", "501-1000", "1001+"]
    vocab = MOCK_EVENT_VOCAB[source]
    rows: list[dict] = []
    for o in range(n_objects):
        object_id = f"hs_{o:05d}"
        object_type = rng.choice(object_types)
        owner_id = f"ow_{rng.randint(0, 9):02d}"
        lifecycle = rng.choice(lifecycle_stages)
        lead_src = rng.choice(sources_list)
        industry = rng.choice(industries)
        size = rng.choice(company_sizes)
        n_events = rng.randint(*events_per_object)
        for e in range(n_events):
            event_type = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span))
            rows.append({
                "object_id": object_id,
                "object_type": object_type,
                "event_type": event_type,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "owner_id": owner_id,
                "property_lifecycle_stage": lifecycle,
                "property_lead_source": lead_src,
                "property_industry": industry,
                "property_company_size": size,
            })
    rows.sort(key=lambda r: r["ts"])
    return rows


def gen_mock_stripe(client: str, source: str, month: str, n_customers: int, events_per_customer: tuple[int, int]) -> list[dict]:
    rng = random.Random(stable_seed(client, source, month))
    start, end = month_window(month)
    span = int((end - start).total_seconds())
    plan_amounts = {
        "starter_monthly": 4900,
        "growth_monthly": 19900,
        "scale_monthly": 49900,
        "enterprise_monthly": 199900,
        "starter_annual": 49000,
        "growth_annual": 199000,
        "scale_annual": 499000,
    }
    plan_ids = list(plan_amounts.keys())
    statuses = ["succeeded", "failed", "refunded", "pending"]
    vocab = MOCK_EVENT_VOCAB[source]
    rows: list[dict] = []
    for c in range(n_customers):
        customer_id = f"cus_{c:08d}"
        plan_id = rng.choice(plan_ids)
        plan_amount = plan_amounts[plan_id]
        n_events = rng.randint(*events_per_customer)
        for e in range(n_events):
            event_type = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span))
            # Stripe amount semantics: paid invoices and charge events carry amounts;
            # cancellations / customer.created carry zero.
            if "paid" in event_type or "succeeded" in event_type:
                amount = plan_amount
                status = "succeeded"
            elif "failed" in event_type:
                amount = plan_amount
                status = "failed"
            elif "refunded" in event_type:
                amount = -plan_amount
                status = "refunded"
            else:
                amount = 0
                status = "n/a"
            rows.append({
                "event_id": f"evt_{c:08d}_{e:04d}",
                "customer_id": customer_id,
                "event_type": event_type,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "currency": "usd",
                "amount_cents": str(amount),
                "plan_id": plan_id,
                "status": status,
            })
    rows.sort(key=lambda r: r["ts"])
    return rows


