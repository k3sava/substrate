    rows: list[dict] = []
    for u in range(n_users):
        user_id = f"sg_{u:05d}"
        anon_id = f"anon_{u:05d}"
        plan = rng.choice(plans)
        signup_source = rng.choice(sources_list)
        persona = rng.choice(personas)
        team_size = rng.choice([1, 2, 5, 10])
        n_events = rng.randint(*events_per_user)
        for e in range(n_events):
            event_name = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span))
            rows.append({
                "event_id": f"sge_{u:05d}_{e:04d}",
                "user_id": user_id,
                "anonymous_id": anon_id,
                "event_name": event_name,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "source": rng.choice(sub_sources),
                "property_plan": plan,
                "property_team_size": str(team_size),
                "property_signup_source": signup_source,
                "property_persona": persona,
            })
    rows.sort(key=lambda r: r["ts"])
    return rows


def gen_mock_ga4(client: str, source: str, month: str, n_clients: int, events_per_client: tuple[int, int]) -> list[dict]:
    rng = random.Random(stable_seed(client, source, month))
    start, end = month_window(month)
    span = int((end - start).total_seconds())
    pages = ["/", "/pricing", "/product", "/blog", "/blog/post-a", "/blog/post-b", "/contact", "/signup", "/login", "/dashboard"]
    referrers = ["google.com", "twitter.com", "linkedin.com", "(direct)", "newsletter.example.com", "producthunt.com"]
    sources_list = ["organic", "paid-search", "referral", "direct", "social"]
    personas = ["sdr-lead", "ops-lead", "founder-led"]
    vocab = MOCK_EVENT_VOCAB[source]
    rows: list[dict] = []
    for c in range(n_clients):
        client_id = f"GA{rng.randint(1_000_000, 9_999_999)}.{rng.randint(1_000_000, 9_999_999)}"
        signup_source = rng.choice(sources_list)
        persona = rng.choice(personas)
        n_events = rng.randint(*events_per_client)
        for e in range(n_events):
            event_name = weighted_pick(rng, vocab)
            ts = start + timedelta(seconds=rng.randint(0, span))
            rows.append({
                "event_id": f"ga_{c:05d}_{e:04d}",
                "client_id": client_id,
                "event_name": event_name,
                "ts": ts.strftime("%Y-%m-%dT%H:%M:%SZ"),
                "session_id": f"gs_{c:05d}_{e // 5}",
                "property_page_path": rng.choice(pages),
                "property_referrer": rng.choice(referrers),
                "property_signup_source": signup_source,
                "property_persona": persona,
            })
    rows.sort(key=lambda r: r["ts"])
    return rows


MOCK_GENERATORS = {
    "amplitude": lambda c, s, m: gen_mock_amplitude(c, s, m, n_users=120, events_per_user=(20, 80)),
    "posthog":   lambda c, s, m: gen_mock_posthog(c, s, m, n_users=80, events_per_user=(15, 60)),
    "mixpanel":  lambda c, s, m: gen_mock_mixpanel(c, s, m, n_users=60, events_per_user=(20, 60)),
    "hubspot":   lambda c, s, m: gen_mock_hubspot(c, s, m, n_objects=40, events_per_object=(5, 20)),
    "stripe":    lambda c, s, m: gen_mock_stripe(c, s, m, n_customers=30, events_per_customer=(3, 12)),
    "segment":   lambda c, s, m: gen_mock_segment(c, s, m, n_users=70, events_per_user=(15, 50)),
    "ga4":       lambda c, s, m: gen_mock_ga4(c, s, m, n_clients=200, events_per_client=(10, 40)),
}


# --- live API placeholders --------------------------------------------------

def fetch_live(source: str, api_key: str, sources_yaml: dict, month: str) -> list[dict]:
    """Live API fetch placeholder.

    Real implementations would call:
      amplitude: GET https://amplitude.com/api/2/export?start={start}&end={end}
      posthog:   POST https://app.posthog.com/api/projects/<id>/query
      mixpanel:  GET https://data.mixpanel.com/api/2.0/export
      hubspot:   GET https://api.hubapi.com/events/v3/events
      stripe:    GET https://api.stripe.com/v1/events
      segment:   GET https://api.segmentapis.com/sources/<id>/events
      ga4:       GA4 Data API (analyticsdata.googleapis.com)

    These calls require source-specific auth, paging, and decompression. To keep
    the skill zero-dep and not exfiltrate data accidentally during smoke tests,
    we currently raise NotImplementedError; callers fall back to mock-mode and
    log the fallback. When live wiring lands, replace this body with the real
    request. The schema is already mapped per SOURCE_SCHEMAS above.
    """
    raise NotImplementedError(
        f"live fetch for {source} not wired; falling back to mock-mode. "
        f"Implement this call and return rows in the SOURCE_SCHEMAS[{source}] shape."
    )


# --- declared-events drift check --------------------------------------------

def load_events_taxonomy(client: str) -> tuple[set[str], dict | None]:
    """Return the set of declared event names from events.yaml, or (empty, None)."""
    p = SUBSTRATE_ROOT / "clients" / client / "events.yaml"
    if not p.is_file():
        return set(), None
    raw = load_yaml(p) or {}
    declared = set()
    events = raw.get("events", []) or []
    if isinstance(events, list):
        for ev in events:
            if isinstance(ev, dict) and "name" in ev:
                declared.add(ev["name"])
    return declared, raw


def event_field_for_source(source: str) -> str:
    """Which CSV column holds the event name for a given source."""
    if source == "stripe" or source == "hubspot":
        return "event_type"
    return "event_name"


def compute_taxonomy_coverage(rows: list[dict], source: str, declared: set[str]) -> dict:
    if not rows or not declared:
        return {"rows_total": len(rows), "rows_declared": 0, "coverage_pct": 0.0, "undeclared_events": []}
    field = event_field_for_source(source)
    fired_events: dict[str, int] = {}
    declared_count = 0
    for r in rows:
        ev = r.get(field, "")
        fired_events[ev] = fired_events.get(ev, 0) + 1
        if ev in declared:
            declared_count += 1
    undeclared = sorted(
        (ev for ev in fired_events if ev not in declared),
        key=lambda e: -fired_events[e],
    )
    return {
        "rows_total": len(rows),
        "rows_declared": declared_count,
        "coverage_pct": round(declared_count / len(rows) * 100.0, 1) if rows else 0.0,
        "undeclared_events": [
            {"event": ev, "count": fired_events[ev]} for ev in undeclared[:20]
        ],
        "fired_event_count": len(fired_events),
    }


# --- writers ---------------------------------------------------------------

def write_csv(out_path: Path, rows: list[dict], schema: list[str], properties: list[str]) -> None:
    out_path.parent.mkdir(parents=True, exist_ok=True)
    cols = schema + properties
    # Ensure all declared columns exist (fill missing with empty string)
    with out_path.open("w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=cols, extrasaction="ignore")
        writer.writeheader()
        for row in rows:
            filled = {c: row.get(c, "") for c in cols}
            writer.writerow(filled)


def write_manifest(out_path: Path, manifest: dict) -> None:
    out_path.parent.mkdir(parents=True, exist_ok=True)
    out_path.write_text(json.dumps(manifest, indent=2), encoding="utf-8")


def append_log(log_path: Path, entry_lines: list[str]) -> None:
    log_path.parent.mkdir(parents=True, exist_ok=True)
    if log_path.exists():
        existing = log_path.read_text(encoding="utf-8")
    else:
        existing = ""
    block = "\n".join(entry_lines) + "\n"
    log_path.write_text(existing + block, encoding="utf-8")


# --- main pipeline ---------------------------------------------------------

def preflight(client: str) -> tuple[bool, list[str]]:
    fails: list[str] = []
    client_root = SUBSTRATE_ROOT / "clients" / client
    if not client_root.exists():
        fails.append(f"client root missing: clients/{client}/")
        return False, fails
    if not (client_root / "icp").is_dir() and not (client_root / "icp.md").is_file():
        fails.append(f"icp layer missing: clients/{client}/icp/")
    sources_yaml = client_root / "analytics" / "sources.yaml"
    if not sources_yaml.is_file():
        fails.append(f"sources.yaml missing: clients/{client}/analytics/sources.yaml")
    return len(fails) == 0, fails


def select_sources(requested: str, sources_yaml: dict) -> list[str]:
    declared = sources_yaml.get("sources") or {}
    if isinstance(declared, list):
        # list-of-maps form: [{name: amplitude, ...}, ...]
        names = [s.get("name") for s in declared if isinstance(s, dict) and s.get("name")]
    elif isinstance(declared, dict):
        names = list(declared.keys())
    else:
        names = []

    valid_names = [n for n in names if n in SOURCE_SCHEMAS]

    if requested == "all":
        return valid_names
    if requested in valid_names:
        return [requested]
    if requested in SOURCE_SCHEMAS and requested not in valid_names:
        # Source is known to the skill but not declared in sources.yaml
        return []
    return []


def pull_source(client: str, source: str, month: str, sources_yaml: dict, force_mock: bool, dry_run: bool) -> dict:
    """Pull a single source. Returns a manifest entry."""
    schema = SOURCE_SCHEMAS[source]
    props = SOURCE_PROPERTIES[source]
    api_env = SOURCE_API_KEY_ENV[source]
    api_key = os.environ.get(api_env, "")

    declared_events, _ = load_events_taxonomy(client)

    out_dir = SUBSTRATE_ROOT / "clients" / client / "analytics" / source
    csv_path = out_dir / f"{month}.csv"
    manifest_path = out_dir / f"{month}.manifest.json"

    if dry_run:
        return {
            "source": source,
            "month": month,
            "csv_path": str(csv_path),
            "mode": "dry-run",
            "row_count": 0,
            "would_write": True,
        }

    mode = "mock"
    rows: list[dict] = []
    fallback_reason = ""

    if force_mock:
        rows = MOCK_GENERATORS[source](client, source, month)
        mode = "mock-forced"
    elif api_key:
        try:
            rows = fetch_live(source, api_key, sources_yaml, month)
            mode = "live"
        except NotImplementedError as e:
            rows = MOCK_GENERATORS[source](client, source, month)
            mode = "mock-fallback"
            fallback_reason = str(e)
        except Exception as e:  # noqa: BLE001
            rows = MOCK_GENERATORS[source](client, source, month)
            mode = "mock-fallback"
            fallback_reason = f"live fetch failed: {e}"
    else:
        rows = MOCK_GENERATORS[source](client, source, month)
        mode = "mock"
        fallback_reason = f"{api_env} not set in env"

    coverage = compute_taxonomy_coverage(rows, source, declared_events)

    write_csv(csv_path, rows, schema, props)

    # Compute distinct user / id count for the manifest
    id_field = "user_id" if "user_id" in schema else (
        "distinct_id" if "distinct_id" in schema else (
            "customer_id" if "customer_id" in schema else (
                "object_id" if "object_id" in schema else (
                    "client_id" if "client_id" in schema else "event_id"
                )
            )
        )
    )
    distinct_ids = len({r.get(id_field, "") for r in rows})

    if rows:
        ts_min = min(r["ts"] for r in rows)
        ts_max = max(r["ts"] for r in rows)
    else:
        ts_min = ts_max = ""

    manifest = {
        "source": source,
        "client": client,
        "month": month,
        "mode": mode,
        "fallback_reason": fallback_reason,
        "row_count": len(rows),
        "distinct_ids": distinct_ids,
        "id_field": id_field,
        "ts_min": ts_min,
        "ts_max": ts_max,
        "schema": schema + props,
        "events_taxonomy": coverage,
        "fetched_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "api_key_env": api_env,
        "api_key_present": bool(api_key),
        "csv_path": str(csv_path.relative_to(SUBSTRATE_ROOT)),
    }
    write_manifest(manifest_path, manifest)

    return manifest


def main() -> int:
    p = argparse.ArgumentParser(description="analytics-pull, source-system data ingest into per-client substrate")
    p.add_argument("--client", required=True)
    p.add_argument("--source", default="all")
    p.add_argument("--month", default=None, help="YYYY-MM, default: previous calendar month")
    p.add_argument("--mock", action="store_true", help="force mock-mode for all sources")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--strict-substrate", action="store_true", help="hard-refuse on substrate gap")
    args = p.parse_args()

    ok, fails = preflight(args.client)
    if not ok:
        print("REFUSED: substrate-gap", file=sys.stderr)
        for f in fails:
            print(f"  - {f}", file=sys.stderr)
        return 3

    month = args.month or previous_month_label()
    try:
        month_window(month)
    except ValueError as e:
        print(f"REFUSED: invalid-month, {e}", file=sys.stderr)
        return 4

    sources_yaml_path = SUBSTRATE_ROOT / "clients" / args.client / "analytics" / "sources.yaml"
    sources_yaml = load_yaml(sources_yaml_path) or {}
    if not sources_yaml.get("sources"):
        print(
            "REFUSED: missing-sources-yaml-entries, "
            f"clients/{args.client}/analytics/sources.yaml has no `sources:` block.",
            file=sys.stderr,
        )
        return 3

    selected = select_sources(args.source, sources_yaml)
    if not selected:
        if args.source == "all":
            print("REFUSED: no-known-sources-declared", file=sys.stderr)
            print(f"  declared sources do not match any known schema: {list(SOURCE_SCHEMAS)}", file=sys.stderr)
            return 3
        print(f"REFUSED: source-not-declared, {args.source!r} not in sources.yaml", file=sys.stderr)
        return 3

    print(f"[analytics-pull] client={args.client} month={month} sources={','.join(selected)} mock={args.mock}", file=sys.stderr)

    manifests: list[dict] = []
    failures: list[str] = []
    for src in selected:
        try:
            m = pull_source(args.client, src, month, sources_yaml, args.mock, args.dry_run)
            manifests.append(m)
            print(
                f"  · {src}: mode={m['mode']} rows={m['row_count']} ids={m['distinct_ids']} "
                f"coverage={m['events_taxonomy'].get('coverage_pct', 0):.1f}%",
                file=sys.stderr,
            )
        except Exception as e:  # noqa: BLE001
            failures.append(f"{src}: {e}")
            print(f"  · {src}: FAILED, {e}", file=sys.stderr)

    log_path = SUBSTRATE_ROOT / "clients" / args.client / "analytics" / "_log" / f"{datetime.now(timezone.utc).strftime('%Y-%m-%d')}-pull.md"
    log_lines = [
        f"## analytics-pull, {datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')}",
        "",
        f"- Client: {args.client}",
        f"- Month: {month}",
        f"- Sources requested: {args.source}",
        f"- Sources resolved: {', '.join(selected)}",
        f"- Mock-forced: {args.mock}",
        f"- Dry-run: {args.dry_run}",
        "",
        "### Results",
        "",
    ]
    for m in manifests:
        log_lines.append(
            f"- {m['source']}: mode={m['mode']} rows={m['row_count']} ids={m['distinct_ids']} "
            f"coverage={m['events_taxonomy'].get('coverage_pct', 0):.1f}% "
            f"undeclared_events={len(m['events_taxonomy'].get('undeclared_events', []))}"
        )
    if failures:
        log_lines.append("")
        log_lines.append("### Failures")
        log_lines.append("")
        for fail in failures:
            log_lines.append(f"- {fail}")
    if not args.dry_run:
        append_log(log_path, log_lines)

    if failures:
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
