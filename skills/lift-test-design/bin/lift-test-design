#!/usr/bin/env python3
"""lift-test-design, design a holdout / geo / synthetic-control / pre-post test.

Computes sample size, MDE, power, audience-holdout shape, randomization protocol,
validity window. Writes test spec + measurement contract that opens a goal.
Refuses without baseline + canonical positioning + metric-tree.yaml.

Per the incrementality-not-attribution + measurement-correlated-short-signals
patterns, the spec carries the full math, names the corroborating signals, and
declares a contradiction position on short-feedback-vs-long-term-holdouts (fast
loop vs long-window holdout) with the conditioning evidence.

Surfaces: paid-ads, email, retention, abm, content, onboarding.
Modes: geo-holdout, audience-holdout, psa-control, synthetic-control,
       switchback, pre-post.

Usage:
    lift-test-design --client <client> --surface <surface> --mode <mode> \\
        --metric <metric-id-from-tree> \\
        --baseline <weekly-rate-or-count> --quarter <YYYY-Q[1-4]> \\
        [--mde-pct <float>] [--alpha <float>] [--power <float>] \\
        [--treatment-share <float>] [--predicted-p <float>]

Exit codes:
    0, design + contract written
    1, written with warnings
    3, refused (substrate gap)
    4, invalid args
"""

from __future__ import annotations

import argparse
import math
import os
import re
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

SUBSTRATE_ROOT = Path(
    os.environ.get("SUBSTRATE_ROOT")
    or os.environ.get("FLYWHEEL_ROOT")
    or Path(__file__).resolve().parents[3]
)


VALID_SURFACES = {"paid-ads", "email", "retention", "abm", "content", "onboarding"}
VALID_MODES = {"geo-holdout", "audience-holdout", "psa-control", "synthetic-control",
               "switchback", "pre-post"}

# Surface-mode fit map. "good" / "fair" / "poor".
SURFACE_MODE_FIT: dict[tuple[str, str], str] = {
    # paid-ads
    ("paid-ads", "geo-holdout"): "good",
    ("paid-ads", "audience-holdout"): "fair",
    ("paid-ads", "psa-control"): "good",
    ("paid-ads", "synthetic-control"): "fair",
    ("paid-ads", "switchback"): "poor",
    ("paid-ads", "pre-post"): "fair",
    # email
    ("email", "geo-holdout"): "poor",
    ("email", "audience-holdout"): "good",
    ("email", "psa-control"): "poor",
    ("email", "synthetic-control"): "fair",
    ("email", "switchback"): "fair",
    ("email", "pre-post"): "fair",
    # retention (in-product nudge)
    ("retention", "geo-holdout"): "poor",
    ("retention", "audience-holdout"): "good",
    ("retention", "psa-control"): "poor",
    ("retention", "synthetic-control"): "fair",
    ("retention", "switchback"): "good",
    ("retention", "pre-post"): "fair",
    # abm
    ("abm", "geo-holdout"): "fair",
    ("abm", "audience-holdout"): "good",
    ("abm", "psa-control"): "poor",
    ("abm", "synthetic-control"): "good",
    ("abm", "switchback"): "poor",
    ("abm", "pre-post"): "fair",
    # content
    ("content", "geo-holdout"): "fair",
    ("content", "audience-holdout"): "fair",
    ("content", "psa-control"): "poor",
