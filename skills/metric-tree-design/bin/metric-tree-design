#!/usr/bin/env python3
"""metric-tree-design, design the client's north-star + supporting metric tree.

Per the metric-tree-not-metric-stack pattern, organize metrics structurally:
north-star (root), 2-4 input metrics (branches), supporting metrics, behavioral
leaves. The skill produces a markdown tree (with ASCII tree art) and a YAML
artifact. Refuses without ICP. Refuses with >4 input metrics or >12 leaves
(tree must fit on one page).

Usage:
    metric-tree-design --client <client> [--north-star <metric-name>] \
        [--input-axes acquisition,activation,retention,monetization,referral] \
        [--depth 3] [--update]

Outputs:
    clients/<client>/analytics/metric-tree.md
    clients/<client>/analytics/metric-tree.yaml
    clients/<client>/analytics/metric-tree-audit-checklist.md

Exit codes:
    0, tree written
    1, written with warnings (data-gap or cadence-missing flags)
    3, refused (substrate gap, missing ICP, too-many-inputs, too-many-leaves)
    4, invalid args
"""

from __future__ import annotations

import argparse
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

SUBSTRATE_ROOT = Path(
    os.environ.get("SUBSTRATE_ROOT")
    or os.environ.get("FLYWHEEL_ROOT")
    or Path(__file__).resolve().parents[3]
)


# Default tree templates per axis-frame. Each template is a per-input-axis list
# of (supporting metric, behavioral leaf) tuples. The skill instantiates a
# default tree from the template, then surfaces gaps for the operator to fill.

