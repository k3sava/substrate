#!/usr/bin/env python3
"""ticket-cluster-analysis, cluster a support ticket export by theme.

Reads a support tickets CSV, runs a manual taxonomy pass plus TF-IDF residual
clustering on the subject + body, and writes a per-cluster report covering
sizes, sample tickets verbatim, common tokens, suggested help-content topics
in customer language, and the recommended downstream skill.

Usage:
    ticket-cluster-analysis --client <client> --tickets <path> \
        [--top-clusters 10] [--min-cluster-size 3] [--out-dir <path>]

Outputs:
    clients/<client>/support/ticket-clusters-<date>.md
    clients/<client>/support/ticket-clusters-<date>.json
    clients/<client>/support/ticket-clusters-<date>.csv

Exit codes:
    0, report written
    3, preflight refusal (substrate gap, empty-corpus, too-few-tickets, schema-mismatch)
    4, invalid args

Per the tickets-are-product-feedback-channel pattern, this skill treats the
ticket corpus as product knowledge. Per frontline-as-pmm-substrate, the cluster
output is the operator-readable index into that source. Clustering is
deterministic (manual taxonomy + TF-IDF residuals); operators can audit every
assignment.
"""

from __future__ import annotations

import argparse
import csv
import json
import math
import os
import re
import sys
from collections import Counter, defaultdict
from datetime import datetime, timezone
from pathlib import Path

SUBSTRATE_ROOT = Path(
    os.environ.get("SUBSTRATE_ROOT")
    or os.environ.get("FLYWHEEL_ROOT")
    or Path(__file__).resolve().parents[3]
)

MIN_TICKETS = 50

# Manual taxonomy of support themes. Each entry: (theme_id, keywords list,
# label, suggested help-content topic stem, recommended downstream skill).
# Keywords match against subject + body, lowercased, word-boundary regex.
# Tickets can match multiple themes (cluster is the union).
TAXONOMY: list[tuple[str, list[str], str, str, str]] = [
